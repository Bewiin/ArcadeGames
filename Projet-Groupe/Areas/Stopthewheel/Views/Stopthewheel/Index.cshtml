@{
    ViewData["Title"] = "Stop The Wheel";
}

<style>
    /* ── Layout ─────────────────────────────── */
    #stw-game {
        max-width: 960px;
        margin: 0 auto;
        text-align: center;
    }

    .stw-arena {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 2.5rem;
        margin-top: 1.5rem;
        flex-wrap: wrap;
    }

    /* ── Wheel ──────────────────────────────── */
    .stw-wheel-section {
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .stw-pointer {
        color: #ff2d78;
        font-size: 2.2rem;
        text-shadow: 0 0 14px #ff2d78;
        line-height: 1;
        margin-bottom: -10px;
        z-index: 2;
        position: relative;
    }

    #stwCanvas {
        border-radius: 50%;
        box-shadow: 0 0 32px rgba(0,212,255,0.25), 0 0 80px rgba(0,212,255,0.08);
    }

    .stw-legend {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem 1rem;
        justify-content: center;
        margin-top: 1.2rem;
        font-family: 'Exo 2', sans-serif;
        font-size: 0.78rem;
        max-width: 560px;
        color: var(--text-muted);
    }

    /* ── Lever ──────────────────────────────── */
    .stw-lever {
        display: flex;
        flex-direction: column;
        align-items: center;
        cursor: pointer;
        user-select: none;
        padding: 0 1rem;
    }

    /* L'assemblage entier pivote autour de son bas */
    .stw-lever-assembly {
        display: flex;
        flex-direction: column;
        align-items: center;
        transform-origin: bottom center;
        transition: transform 0.18s ease-in;
        will-change: transform;
    }

    .stw-lever-assembly.pulled {
        transform: rotate(32deg);
    }

    .stw-lever-assembly.returning {
        transform: rotate(0deg);
        transition: transform 0.5s cubic-bezier(0.34, 1.45, 0.64, 1);
    }

    /* Bille 3D */
    .stw-lever-ball {
        width: 54px;
        height: 54px;
        border-radius: 50%;
        flex-shrink: 0;
        background: radial-gradient(circle at 35% 28%,
            #ffaacc 0%,
            #ee1155 38%,
            #7a0018 80%,
            #3a0008 100%);
        box-shadow:
            inset -5px -5px 12px rgba(0,0,0,0.6),
            inset  3px  3px  8px rgba(255,180,200,0.3),
            0 0 22px rgba(255,45,120,0.65),
            0 6px 14px rgba(0,0,0,0.55);
        border: 1px solid rgba(255,130,160,0.2);
        margin-bottom: -1px;
    }

    /* Tige chromée */
    .stw-lever-pole {
        width: 14px;
        height: 170px;
        flex-shrink: 0;
        background: linear-gradient(90deg,
            #111  0%,
            #555 15%,
            #bbb 33%,
            #eee 50%,
            #bbb 67%,
            #555 85%,
            #111 100%);
        border-radius: 7px;
        box-shadow:
            3px 0 8px rgba(0,0,0,0.45),
            -1px 0 3px rgba(255,255,255,0.07);
    }

    /* Socle */
    .stw-lever-base {
        width: 72px;
        height: 24px;
        background: linear-gradient(180deg, #5c5c5c 0%, #2e2e2e 55%, #111 100%);
        border-radius: 6px;
        box-shadow:
            0 5px 12px rgba(0,0,0,0.75),
            inset 0  1px 0 rgba(255,255,255,0.13),
            inset 0 -1px 0 rgba(0,0,0,0.4);
        border: 1px solid rgba(0,212,255,0.22);
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        z-index: 1;
    }

    /* Axe central du socle */
    .stw-lever-pivot {
        width: 18px;
        height: 18px;
        border-radius: 50%;
        background: radial-gradient(circle at 35% 35%, #aaa, #555, #222);
        box-shadow:
            inset -2px -2px 5px rgba(0,0,0,0.6),
            inset  1px  1px 3px rgba(255,255,255,0.15);
    }

    .stw-lever-label {
        margin-top: 0.7rem;
        font-family: 'Orbitron', monospace;
        font-size: 0.6rem;
        letter-spacing: 2px;
        color: var(--text-muted);
    }

    /* ── Score Panel ────────────────────────── */
    .stw-panel {
        background: var(--bg-card);
        border: 1px solid rgba(0,212,255,0.2);
        border-radius: 14px;
        padding: 1.5rem 1.8rem;
        min-width: 190px;
    }

    .stw-panel-label {
        font-family: 'Orbitron', monospace;
        font-size: 0.65rem;
        letter-spacing: 3px;
        color: var(--text-muted);
        margin-bottom: 0.2rem;
    }

    .stw-score {
        font-family: 'Orbitron', monospace;
        font-size: 3.2rem;
        font-weight: 900;
        color: var(--neon-blue);
        text-shadow: var(--glow-blue);
        line-height: 1;
        transition: color 0.3s;
    }

    .stw-score.flash-lose {
        color: #ff2d78;
        text-shadow: var(--glow-pink);
    }

    .stw-target-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin: 1rem 0 0.3rem;
        font-family: 'Exo 2', sans-serif;
        font-size: 0.75rem;
        color: var(--text-muted);
    }

    .stw-progress-bar {
        width: 100%;
        height: 8px;
        background: rgba(255,255,255,0.05);
        border-radius: 4px;
        overflow: hidden;
        border: 1px solid rgba(0,212,255,0.15);
    }

    .stw-progress-fill {
        height: 100%;
        background: linear-gradient(90deg, var(--neon-blue), var(--neon-pink));
        border-radius: 4px;
        transition: width 0.5s ease;
        box-shadow: 0 0 8px rgba(0,212,255,0.4);
        width: 0%;
    }

    .stw-result-box {
        margin-top: 1.4rem;
        min-height: 64px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.2rem;
    }

    .stw-result-emoji {
        font-size: 2.2rem;
        line-height: 1;
    }

    .stw-result-text {
        font-family: 'Exo 2', sans-serif;
        font-size: 0.85rem;
        font-weight: 600;
        min-height: 1.2em;
    }

    /* ── Modal partagée ────────────────────── */
    .stw-modal {
        position: fixed;
        inset: 0;
        z-index: 900;
        display: none;
        align-items: center;
        justify-content: center;
    }

    .stw-modal.open { display: flex; }

    .stw-modal-card {
        border-radius: 20px;
        padding: 2.5rem 3rem;
        text-align: center;
        min-width: 320px;
        max-width: 440px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
        position: relative;
    }

    .stw-modal-spin-btn {
        margin-top: 0.5rem;
        font-family: 'Orbitron', monospace;
        font-size: 0.85rem;
        letter-spacing: 2px;
        background: linear-gradient(135deg, var(--neon-pink), var(--neon-purple));
        color: #fff;
        border: none;
        border-radius: 10px;
        padding: 0.8rem 2.2rem;
        cursor: pointer;
        box-shadow: var(--glow-pink);
        transition: transform 0.15s, box-shadow 0.15s;
    }

    .stw-modal-spin-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 0 20px #ff2d78, 0 0 40px rgba(255,45,120,0.5);
    }

    /* ── Modal Crâne ────────────────────── */
    .stw-skull-modal { background: rgba(7,7,15,0.92); backdrop-filter: blur(8px); }

    .stw-skull-modal .stw-modal-card {
        background: radial-gradient(ellipse at 50% 30%, #1f0008 0%, #0a0010 100%);
        border: 1px solid #ff2d78;
        box-shadow: 0 0 60px rgba(255,45,120,0.35), inset 0 0 50px rgba(180,0,40,0.08);
    }

    .stw-skull-icon {
        font-size: 6rem;
        line-height: 1;
        animation: skull-shake 0.6s ease-in-out;
    }

    @@keyframes skull-shake {
        0%,100% { transform: rotate(0deg) scale(1); }
        15%     { transform: rotate(-12deg) scale(1.05); }
        30%     { transform: rotate(12deg)  scale(1.05); }
        45%     { transform: rotate(-8deg); }
        60%     { transform: rotate(8deg); }
        75%     { transform: rotate(-4deg); }
    }

    .stw-skull-title {
        font-family: 'Orbitron', monospace;
        font-size: 1.6rem;
        font-weight: 900;
        color: #ff2d78;
        text-shadow: var(--glow-pink);
        letter-spacing: 4px;
    }

    .stw-skull-lost-label {
        font-family: 'Exo 2', sans-serif;
        font-size: 0.8rem;
        color: var(--text-muted);
        letter-spacing: 2px;
        text-transform: uppercase;
    }

    .stw-skull-count {
        font-family: 'Orbitron', monospace;
        font-size: 4rem;
        font-weight: 900;
        color: #ff2d78;
        text-shadow: 0 0 16px #ff2d78, 0 0 40px rgba(255,45,120,0.5);
        line-height: 1;
        transition: font-size 0.1s;
    }

    /* ── Modal Étoile ───────────────────── */
    .stw-star-modal { background: rgba(7,7,15,0.88); backdrop-filter: blur(8px); }

    .stw-star-modal .stw-modal-card {
        background: #080814;
        border: 2px solid #FFD700;
        animation: rainbow-glow 1.8s linear infinite;
    }

    @@keyframes rainbow-glow {
        0%   { box-shadow: 0 0 40px #ff0044, 0 0 80px rgba(255,0,68,0.2);   border-color: #ff0044; }
        16%  { box-shadow: 0 0 40px #ff8800, 0 0 80px rgba(255,136,0,0.2);  border-color: #ff8800; }
        33%  { box-shadow: 0 0 40px #ffe000, 0 0 80px rgba(255,224,0,0.2);  border-color: #ffe000; }
        50%  { box-shadow: 0 0 40px #00ff88, 0 0 80px rgba(0,255,136,0.2);  border-color: #00ff88; }
        66%  { box-shadow: 0 0 40px #00d4ff, 0 0 80px rgba(0,212,255,0.2);  border-color: #00d4ff; }
        83%  { box-shadow: 0 0 40px #b44fff, 0 0 80px rgba(180,79,255,0.2); border-color: #b44fff; }
        100% { box-shadow: 0 0 40px #ff0044, 0 0 80px rgba(255,0,68,0.2);   border-color: #ff0044; }
    }

    .stw-star-icon {
        font-size: 5.5rem;
        line-height: 1;
        animation: star-pop 0.5s cubic-bezier(0.34,1.56,0.64,1);
        filter: drop-shadow(0 0 16px rgba(255,215,0,0.8));
    }

    @@keyframes star-pop {
        0%   { transform: scale(0); opacity: 0; }
        100% { transform: scale(1); opacity: 1; }
    }

    .stw-star-gained {
        font-family: 'Orbitron', monospace;
        font-weight: 900;
        color: #FFD700;
        text-shadow: 0 0 14px rgba(255,215,0,0.8);
        line-height: 1;
        animation: pts-grow 0.6s cubic-bezier(0.34,1.56,0.64,1);
    }

    @@keyframes pts-grow {
        0%   { transform: scale(0.3); opacity: 0; }
        60%  { transform: scale(1.15); }
        100% { transform: scale(1);   opacity: 1; }
    }

    .stw-star-total {
        font-family: 'Exo 2', sans-serif;
        font-size: 0.9rem;
        color: var(--text-muted);
    }

    .stw-star-total span {
        color: var(--neon-blue);
        font-weight: 700;
    }

    /* ── Mini-game ──────────────────────────── */
    .stw-overlay {
        position: fixed;
        inset: 0;
        background: rgba(7,7,15,0.94);
        backdrop-filter: blur(6px);
        z-index: 1000;
        display: none;
    }

    .stw-overlay-header {
        text-align: center;
        padding: 2.5rem 1rem 1rem;
    }

    .stw-overlay-header h2 {
        font-size: 1.8rem;
        color: #FFD700;
        text-shadow: 0 0 12px rgba(255,215,0,0.6);
        margin-bottom: 0.5rem;
    }

    .stw-overlay-header p {
        color: var(--text-muted);
        font-family: 'Exo 2', sans-serif;
    }

    .stw-countdown {
        font-family: 'Orbitron', monospace;
        font-size: 3rem;
        font-weight: 900;
        color: var(--neon-pink);
        text-shadow: var(--glow-pink);
        margin-top: 0.5rem;
    }

    .stw-troll-btn {
        position: absolute;
        font-family: 'Orbitron', monospace;
        font-size: 0.9rem;
        letter-spacing: 1px;
        background: linear-gradient(135deg, #FFD700, #ff8800);
        color: #000;
        border: none;
        border-radius: 10px;
        padding: 1rem 2rem;
        cursor: pointer;
        box-shadow: 0 0 24px rgba(255,215,0,0.45);
        transition: box-shadow 0.15s;
        white-space: nowrap;
    }

    .stw-troll-btn:hover {
        box-shadow: 0 0 40px rgba(255,215,0,0.7);
    }

    .stw-overlay-result {
        display: none;
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        text-align: center;
    }

    .stw-overlay-result p {
        font-family: 'Orbitron', monospace;
        font-size: 1.3rem;
        margin-bottom: 1.5rem;
    }
</style>

<div id="stw-game">
    <h1 class="neon-blue mb-0">STOP THE WHEEL</h1>
    <p style="font-family:'Exo 2',sans-serif;font-size:0.8rem;color:rgba(232,232,240,0.06);letter-spacing:3px;margin:0.1rem 0 0;">Trouve le jeu secret ...</p>
    <hr class="neon-divider mx-auto" style="max-width:280px">

    <div class="stw-arena">

        <!-- Roue -->
        <div class="stw-wheel-section">
            <div class="stw-pointer">▼</div>
            <canvas id="stwCanvas" width="560" height="560"></canvas>
            <div class="stw-legend">
                <span style="color:#c8a200">⭐ Étoile &nbsp;+100</span>
                <span style="color:#9933ee">👑 Couronne +50</span>
                <span style="color:#00d4ff">⚡ Éclair &nbsp;+25</span>
                <span>💣 Bombe &nbsp;&nbsp;+0</span>
                <span style="color:#ff2d78">💀 Crâne &nbsp;&nbsp;×0</span>
            </div>
        </div>

        <!-- Levier -->
        <div class="stw-lever" id="stwLever" title="Tirez le levier !">
            <div class="stw-lever-assembly" id="stwHandle">
                <div class="stw-lever-ball"></div>
                <div class="stw-lever-pole"></div>
            </div>
            <div class="stw-lever-base">
                <div class="stw-lever-pivot"></div>
            </div>
            <div class="stw-lever-label">TIRER</div>
        </div>

        <!-- Panel score -->
        <div class="stw-panel">
            <div class="stw-panel-label">SCORE</div>
            <div class="stw-score" id="stwScore">0</div>

            <div class="stw-target-row">
                <span>Objectif mini-jeu</span>
                <span style="color:var(--neon-pink);font-weight:700">500</span>
            </div>
            <div class="stw-progress-bar">
                <div class="stw-progress-fill" id="stwProgress"></div>
            </div>

            <div class="stw-result-box">
                <div class="stw-result-emoji" id="stwResultEmoji"></div>
                <div class="stw-result-text" id="stwResultText"></div>
            </div>
        </div>

    </div>
</div>

<!-- Modal Crâne -->
<div class="stw-modal stw-skull-modal" id="stwSkullModal">
    <div class="stw-modal-card">
        <div class="stw-skull-icon">💀</div>
        <div class="stw-skull-title">CRÂNE !</div>
        <div class="stw-skull-lost-label">Points perdus</div>
        <div class="stw-skull-count" id="stwSkullCount">0</div>
        <button class="stw-modal-spin-btn" id="stwSkullSpin">🎰 TIRER</button>
    </div>
</div>

<!-- Modal Étoile -->
<div class="stw-modal stw-star-modal" id="stwStarModal">
    <div class="stw-modal-card">
        <div class="stw-star-icon">⭐</div>
        <div class="stw-star-gained" id="stwStarGained">+100</div>
        <div class="stw-star-total">Total : <span id="stwStarTotal">0</span></div>
        <button class="stw-modal-spin-btn" id="stwStarSpin">🎰 TIRER</button>
    </div>
</div>

<!-- Overlay mini-jeu -->
<div class="stw-overlay" id="stwOverlay">
    <div class="stw-overlay-header">
        <h2 class="neon-pulse">🎉 MINI-JEU SECRET DÉBLOQUÉ !</h2>
        <p>Clique sur le bouton pour réclamer ton bonus !</p>
        <div class="stw-countdown" id="stwCountdown">10</div>
    </div>

    <button class="stw-troll-btn" id="stwTrollBtn">RÉCLAMER MON BONUS 🎁</button>

    <div class="stw-overlay-result" id="stwOverlayResult">
        <p id="stwOverlayMsg"></p>
        <button class="btn btn-primary" id="stwCloseOverlay">Retour au jeu</button>
    </div>
</div>

@section Scripts {
<script>
(function () {
    /* ── Symboles ───────────────────────────────────── */
    const SYM = {
        star:  { emoji: '⭐', label: 'Étoile',   pts: 100,  color: '#7a5c00', rim: '#c8a200' },
        crown: { emoji: '👑', label: 'Couronne',  pts: 50,   color: '#4a1580', rim: '#9933ee' },
        bolt:  { emoji: '⚡', label: 'Éclair',    pts: 25,   color: '#005566', rim: '#00d4ff' },
        bomb:  { emoji: '💣', label: 'Bombe',     pts: 0,    color: '#1a1a30', rim: '#444466' },
        skull: { emoji: '💀', label: 'Crâne',     pts: null, color: '#660011', rim: '#ff2d78' },
    };

    /* 30 segments: 3 étoiles, 3 crânes, 8 couronnes, 8 éclairs, 8 bombes
       Disposition gloutonne : évite au maximum les symboles adjacents identiques */
    function buildWheel() {
        const counts = { star: 3, skull: 3, crown: 8, bolt: 8, bomb: 8 };
        const result = [];

        for (let i = 0; i < 30; i++) {
            const prev  = result[result.length - 1] ?? null;
            const first = result[0] ?? null;
            const isLast = i === 29;

            /* Candidats triés par fréquence décroissante, excluant le précédent
               et, sur la dernière case, excluant aussi le premier (fermeture du cercle) */
            const candidates = Object.entries(counts)
                .filter(([k, v]) => v > 0 && k !== prev && !(isLast && k === first))
                .sort((a, b) => b[1] - a[1] || Math.random() - 0.5);

            /* Fallback si contrainte circulaire impossible à tenir */
            const pool = candidates.length > 0
                ? candidates
                : Object.entries(counts).filter(([, v]) => v > 0).sort((a, b) => b[1] - a[1]);

            const [[chosen]] = pool;
            result.push(chosen);
            counts[chosen]--;
        }
        return result;
    }

    const segments = buildWheel();

    const N          = segments.length;         // 30
    const SEG        = (2 * Math.PI) / N;
    const TARGET     = 500;
    const PROXIMITY  = 90;                      // px – distance de fuite du bouton

    let angle        = 0;
    let spinning     = false;
    let score        = 0;
    let mgTriggered  = false;

    /* ── Canvas ─────────────────────────────────────── */
    const canvas = document.getElementById('stwCanvas');
    const ctx    = canvas.getContext('2d');
    const CX     = canvas.width  / 2;
    const CY     = canvas.height / 2;
    const R      = CX - 14;

    function draw() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);

        /* Halo extérieur */
        const glow = ctx.createRadialGradient(CX, CY, R - 4, CX, CY, R + 18);
        glow.addColorStop(0, 'rgba(0,212,255,0.28)');
        glow.addColorStop(1, 'rgba(0,212,255,0)');
        ctx.beginPath();
        ctx.arc(CX, CY, R + 18, 0, 2 * Math.PI);
        ctx.fillStyle = glow;
        ctx.fill();

        /* Segments */
        for (let i = 0; i < N; i++) {
            const s0  = angle + i * SEG;
            const s1  = s0 + SEG;
            const sym = SYM[segments[i]];

            ctx.beginPath();
            ctx.moveTo(CX, CY);
            ctx.arc(CX, CY, R, s0, s1);
            ctx.closePath();
            ctx.fillStyle = sym.color;
            ctx.fill();
            ctx.strokeStyle = '#07070f';
            ctx.lineWidth = 1.5;
            ctx.stroke();

            /* Emoji centré dans le segment */
            ctx.save();
            ctx.translate(CX, CY);
            ctx.rotate(s0 + SEG / 2);
            ctx.font = '18px serif';
            ctx.textAlign    = 'center';
            ctx.textBaseline = 'middle';
            ctx.fillText(sym.emoji, R * 0.72, 0);
            ctx.restore();
        }

        /* Bordure de la roue */
        ctx.beginPath();
        ctx.arc(CX, CY, R, 0, 2 * Math.PI);
        ctx.strokeStyle = '#00d4ff';
        ctx.lineWidth   = 3;
        ctx.stroke();

        /* Moyeu central */
        ctx.beginPath();
        ctx.arc(CX, CY, 22, 0, 2 * Math.PI);
        ctx.fillStyle   = '#07070f';
        ctx.fill();
        ctx.strokeStyle = '#ff2d78';
        ctx.lineWidth   = 3;
        ctx.stroke();

        ctx.beginPath();
        ctx.arc(CX, CY, 7, 0, 2 * Math.PI);
        ctx.fillStyle = '#ff2d78';
        ctx.fill();
    }

    /* ── Spin ───────────────────────────────────────── */
    function spin() {
        if (spinning) return;
        spinning = true;

        /* Animation du levier */
        playLeverSound();
        const handle = document.getElementById('stwHandle');
        handle.classList.remove('returning');
        handle.classList.add('pulled');
        setTimeout(() => {
            handle.classList.add('returning');
            handle.classList.remove('pulled');
        }, 280);

        const rotations = (6 + Math.random() * 6) * 2 * Math.PI;
        const extra     = Math.random() * 2 * Math.PI;
        const delta     = rotations + extra;
        const duration  = 3200 + Math.random() * 1600;
        playSpinSound(duration);
        const t0        = performance.now();
        const a0        = angle;

        function easeOut(t) { return 1 - Math.pow(1 - t, 4); }

        (function loop(now) {
            const p = Math.min((now - t0) / duration, 1);
            angle = a0 + easeOut(p) * delta;
            draw();
            if (p < 1) { requestAnimationFrame(loop); }
            else { spinning = false; resolve(); }
        })(performance.now());
    }

    /* ── Sons (Web Audio API) ───────────────────────── */
    let _ac = null;

    async function getAC() {
        if (!_ac) _ac = new (window.AudioContext || window.webkitAudioContext)();
        if (_ac.state !== 'running') await _ac.resume();
        return _ac;
    }

    async function playLeverSound() {
        try {
            const ac  = await getAC();
            const now = ac.currentTime;
            /* Clac mécanique : grave court + click aigu */
            const thud = ac.createOscillator();
            const gT   = ac.createGain();
            thud.connect(gT); gT.connect(ac.destination);
            thud.type = 'sine';
            thud.frequency.setValueAtTime(180, now);
            thud.frequency.exponentialRampToValueAtTime(55, now + 0.12);
            gT.gain.setValueAtTime(0.6, now);
            gT.gain.exponentialRampToValueAtTime(0.001, now + 0.14);
            thud.start(now); thud.stop(now + 0.15);

            const click = ac.createOscillator();
            const gC    = ac.createGain();
            click.connect(gC); gC.connect(ac.destination);
            click.type = 'square';
            click.frequency.value = 900;
            gC.gain.setValueAtTime(0.25, now);
            gC.gain.exponentialRampToValueAtTime(0.001, now + 0.03);
            click.start(now); click.stop(now + 0.04);
        } catch (e) { console.warn('lever sound:', e); }
    }

    async function playSpinSound(duration) {
        try {
            const ac    = await getAC();
            const now   = ac.currentTime;
            const ticks = 30;
            for (let i = 0; i < ticks; i++) {
                const ratio = i / ticks;
                const tNorm = 1 - Math.pow(1 - ratio, 0.25);
                const t     = now + (duration / 1000) * tNorm;
                const osc   = ac.createOscillator();
                const g     = ac.createGain();
                osc.connect(g); g.connect(ac.destination);
                osc.type = 'square';
                osc.frequency.value = 380 + Math.random() * 120;
                const vol = Math.max(0.06, 0.28 * (1 - ratio * 0.7));
                g.gain.setValueAtTime(vol, t);
                g.gain.exponentialRampToValueAtTime(0.001, t + 0.04);
                osc.start(t); osc.stop(t + 0.05);
            }
        } catch (e) { console.warn('spin sound:', e); }
    }

    async function playDefeatSound() {
        try {
            const ac  = await getAC();
            const now = ac.currentTime;
            const osc = ac.createOscillator();
            const g   = ac.createGain();
            osc.connect(g); g.connect(ac.destination);
            osc.type = 'sawtooth';
            osc.frequency.setValueAtTime(320, now);
            osc.frequency.exponentialRampToValueAtTime(60, now + 2);
            g.gain.setValueAtTime(0.3, now);
            g.gain.exponentialRampToValueAtTime(0.001, now + 2.2);
            osc.start(now); osc.stop(now + 2.2);
        } catch (e) { console.warn('defeat sound:', e); }
    }

    async function playCoinsSound() {
        try {
            const ac  = await getAC();
            const now = ac.currentTime;
            for (let i = 0; i < 10; i++) {
                const osc = ac.createOscillator();
                const g   = ac.createGain();
                osc.connect(g); g.connect(ac.destination);
                const t = now + i * 0.11;
                osc.type = 'sine';
                osc.frequency.setValueAtTime(900 + Math.random() * 500, t);
                osc.frequency.exponentialRampToValueAtTime(1400 + Math.random() * 400, t + 0.07);
                g.gain.setValueAtTime(0.2, t);
                g.gain.exponentialRampToValueAtTime(0.001, t + 0.13);
                osc.start(t); osc.stop(t + 0.14);
            }
        } catch (e) { console.warn('coins sound:', e); }
    }

    /* ── Résultat ───────────────────────────────────── */
    function resolve() {
        const ptr = -Math.PI / 2;
        const rel = ((ptr - angle) % (2 * Math.PI) + 2 * Math.PI) % (2 * Math.PI);
        const idx = Math.floor(rel / SEG) % N;
        const key = segments[idx];
        const sym = SYM[key];

        if (key === 'skull') {
            const lost = score;
            score = 0;
            mgTriggered = false;
            updateUI();
            showResult(sym.emoji, 'CRÂNE ! Tout perdu...', '#ff2d78');
            setTimeout(() => showSkullModal(lost), 400);
        } else if (key === 'star') {
            score += sym.pts;
            updateUI();
            showResult(sym.emoji, `${sym.label} ! +${sym.pts} pts`, '#FFD700');
            setTimeout(() => showStarModal(sym.pts, score), 400);
        } else {
            score += sym.pts;
            const msg = sym.pts > 0 ? `${sym.label} ! +${sym.pts} pts` : 'Bombe. +0 pt';
            showResult(sym.emoji, msg, sym.pts > 0 ? '#00d4ff' : '#555577');
            updateUI();
        }

        if (score >= TARGET && !mgTriggered) {
            mgTriggered = true;
            setTimeout(startMinigame, 1600);
        }
    }

    /* ── Modal Crâne ────────────────────────────────── */
    function showSkullModal(lostScore) {
        playDefeatSound();
        const modal   = document.getElementById('stwSkullModal');
        const countEl = document.getElementById('stwSkullCount');
        modal.classList.add('open');
        animateNumber(countEl, lostScore, 0, 2400);

        document.getElementById('stwSkullSpin').onclick = function () {
            modal.classList.remove('open');
            spin();
        };
    }

    /* ── Modal Étoile ───────────────────────────────── */
    function showStarModal(gained, total) {
        playCoinsSound();
        const modal    = document.getElementById('stwStarModal');
        const gainedEl = document.getElementById('stwStarGained');
        const totalEl  = document.getElementById('stwStarTotal');

        gainedEl.textContent  = `+${gained}`;
        gainedEl.style.fontSize = '1rem';
        modal.classList.add('open');

        /* Le chiffre grossit pendant qu'il monte */
        animateNumber(gainedEl, 0, gained, 900, v => {
            gainedEl.textContent  = `+${v}`;
            const ratio = v / gained;
            gainedEl.style.fontSize = (1 + ratio * 3.5) + 'rem';
        });

        animateNumber(totalEl, total - gained, total, 900);

        document.getElementById('stwStarSpin').onclick = function () {
            gainedEl.style.fontSize = '';
            modal.classList.remove('open');
            spin();
        };
    }

    /* ── Utilitaires ────────────────────────────────── */
    function animateNumber(el, from, to, duration, onTick) {
        const t0 = performance.now();
        const update = (now) => {
            const t   = Math.min((now - t0) / duration, 1);
            const val = Math.round(from + (to - from) * t);
            if (onTick) { onTick(val); }
            else { el.textContent = val; }
            if (t < 1) requestAnimationFrame(update);
        };
        requestAnimationFrame(update);
    }

    function showResult(emoji, text, color) {
        document.getElementById('stwResultEmoji').textContent = emoji;
        const el = document.getElementById('stwResultText');
        el.textContent = text;
        el.style.color = color;
    }

    function updateUI() {
        document.getElementById('stwScore').textContent = score;
        const pct = Math.min((score / TARGET) * 100, 100);
        document.getElementById('stwProgress').style.width = pct + '%';
    }

    /* ── Mini-jeu ───────────────────────────────────── */
    function startMinigame() {
        const overlay  = document.getElementById('stwOverlay');
        const btn      = document.getElementById('stwTrollBtn');
        const countEl  = document.getElementById('stwCountdown');
        const result   = document.getElementById('stwOverlayResult');

        btn.style.display    = '';
        result.style.display = 'none';
        overlay.style.display = 'block';

        let timeLeft = 10;
        let ended    = false;

        countEl.textContent = timeLeft;
        placeBtn(btn);

        const timer = setInterval(() => {
            if (ended) return;
            timeLeft--;
            countEl.textContent = timeLeft;
            if (timeLeft <= 0) {
                ended = true;
                clearInterval(timer);
                score = Math.max(0, score - 50);
                updateUI();
                endMinigame('TROP LENT ! -50 pts 😈', '#ff2d78');
            }
        }, 1000);

        /* Fuite au survol */
        overlay.addEventListener('mousemove', function flee(e) {
            if (ended) return;
            const r  = btn.getBoundingClientRect();
            const bx = r.left + r.width  / 2;
            const by = r.top  + r.height / 2;
            if (Math.hypot(e.clientX - bx, e.clientY - by) < PROXIMITY) {
                placeBtn(btn);
            }
        });

        btn.addEventListener('click', function () {
            if (ended) return;
            ended = true;
            clearInterval(timer);
            endMinigame('BIEN JOUÉ... mais tu ne gagnes rien. 😏', '#FFD700');
        }, { once: true });
    }

    function placeBtn(btn) {
        const ow  = window.innerWidth;
        const oh  = window.innerHeight;
        const bw  = btn.offsetWidth  || 240;
        const bh  = btn.offsetHeight || 58;
        const hdr = 240;
        btn.style.left = Math.max(20, 20 + Math.random() * (ow - bw - 40)) + 'px';
        btn.style.top  = Math.max(hdr, hdr + Math.random() * (oh - bh - hdr - 20)) + 'px';
    }

    function endMinigame(msg, color) {
        document.getElementById('stwTrollBtn').style.display = 'none';
        const msgEl = document.getElementById('stwOverlayMsg');
        msgEl.textContent  = msg;
        msgEl.style.color  = color;
        document.getElementById('stwOverlayResult').style.display = 'block';
    }

    document.getElementById('stwCloseOverlay').addEventListener('click', function () {
        document.getElementById('stwOverlay').style.display = 'none';
    });

    /* ── Init ───────────────────────────────────────── */
    document.getElementById('stwLever').addEventListener('click', spin);
    draw();
})();
</script>
}
