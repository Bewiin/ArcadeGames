@{
    ViewData["Title"] = "Snake Néon";
}

<style>
    /* ── Layout ─────────────────────────────── */
    #snk-game {
        max-width: 700px;
        margin: 0 auto;
        text-align: center;
        user-select: none;
    }

    /* ── Canvas ─────────────────────────────── */
    #snkCanvas {
        display: block;
        margin: 0 auto;
        border-radius: 8px;
        border: 2px solid rgba(0,212,255,0.35);
        box-shadow:
            0 0 30px rgba(0,212,255,0.2),
            0 0 80px rgba(0,212,255,0.06),
            inset 0 0 30px rgba(0,212,255,0.03);
        background: #07070f;
        outline: none;
        transition: border-color 0.4s, box-shadow 0.4s;
    }

    #snkCanvas.max-speed {
        border-color: #ff6600;
        animation: flame-glow 0.9s ease-in-out infinite;
    }

    @@keyframes flame-glow {
        0%, 100% {
            box-shadow:
                0 0 18px #ff4400,
                0 0 40px #ff6600,
                0 0 80px rgba(255,100,0,0.35),
                inset 0 0 20px rgba(255,80,0,0.06);
        }
        50% {
            box-shadow:
                0 0 30px #ff7700,
                0 0 65px #ff5500,
                0 0 120px rgba(255,140,0,0.45),
                inset 0 0 30px rgba(255,100,0,0.1);
        }
    }

    /* ── HUD ─────────────────────────────────── */
    .snk-hud {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.6rem 0.2rem;
        font-family: 'Orbitron', monospace;
    }

    .snk-hud-block { text-align: center; }

    .snk-hud-label {
        font-size: 0.55rem;
        letter-spacing: 3px;
        color: var(--text-muted);
    }

    .snk-hud-value {
        font-size: 1.5rem;
        font-weight: 900;
        color: var(--neon-blue);
        text-shadow: var(--glow-blue);
        line-height: 1.1;
    }

    .snk-hud-value.best { color: #FFD700; text-shadow: 0 0 10px rgba(255,215,0,0.6); }

    .snk-speed-bar-wrap {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.2rem;
        min-width: 120px;
    }

    .snk-speed-bar {
        width: 120px;
        height: 6px;
        background: rgba(255,255,255,0.05);
        border-radius: 3px;
        overflow: hidden;
        border: 1px solid rgba(0,212,255,0.15);
    }

    .snk-speed-fill {
        height: 100%;
        background: linear-gradient(90deg, var(--neon-blue), var(--neon-pink));
        border-radius: 3px;
        transition: width 0.4s ease;
        box-shadow: 0 0 6px rgba(255,45,120,0.4);
    }

    /* ── Overlay ─────────────────────────────── */
    .snk-overlay {
        position: absolute;
        inset: 0;
        border-radius: 8px;
        background: rgba(7,7,15,0.88);
        backdrop-filter: blur(4px);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 1rem;
        pointer-events: none;
        opacity: 0;
        transition: opacity 0.3s;
    }

    .snk-overlay.visible {
        opacity: 1;
        pointer-events: all;
    }

    .snk-overlay-title {
        font-family: 'Orbitron', monospace;
        font-size: 2rem;
        font-weight: 900;
        letter-spacing: 4px;
    }

    .snk-overlay-sub {
        font-family: 'Exo 2', sans-serif;
        font-size: 0.9rem;
        color: var(--text-muted);
        letter-spacing: 1px;
    }

    .snk-overlay-score {
        font-family: 'Orbitron', monospace;
        font-size: 1.1rem;
        color: var(--neon-blue);
        text-shadow: var(--glow-blue);
    }

    .snk-overlay-btn {
        font-family: 'Orbitron', monospace;
        font-size: 0.8rem;
        letter-spacing: 2px;
        background: linear-gradient(135deg, var(--neon-pink), var(--neon-purple));
        color: #fff;
        border: none;
        border-radius: 10px;
        padding: 0.8rem 2.2rem;
        cursor: pointer;
        box-shadow: var(--glow-pink);
        transition: transform 0.15s, box-shadow 0.15s;
        margin-top: 0.5rem;
    }

    .snk-overlay-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 0 24px #ff2d78, 0 0 48px rgba(255,45,120,0.4);
    }

    /* ── Wrapper positionné ───────────────────── */
    .snk-canvas-wrap {
        position: relative;
        display: inline-block;
        width: 560px;
    }

    /* ── Controls hint ───────────────────────── */
    .snk-controls {
        margin-top: 0.8rem;
        font-family: 'Exo 2', sans-serif;
        font-size: 0.72rem;
        color: var(--text-muted);
        letter-spacing: 1px;
    }
</style>

<div id="snk-game">
    <h1 class="neon-pink mb-0">SNAKE NÉON</h1>
    <hr class="neon-divider mx-auto" style="max-width:240px">

    <!-- HUD -->
    <div class="snk-hud">
        <div class="snk-hud-block">
            <div class="snk-hud-label">SCORE</div>
            <div class="snk-hud-value" id="snkScore">0</div>
        </div>
        <div class="snk-speed-bar-wrap">
            <div class="snk-hud-label">VITESSE</div>
            <div class="snk-speed-bar"><div class="snk-speed-fill" id="snkSpeedFill" style="width:10%"></div></div>
        </div>
        <div class="snk-hud-block">
            <div class="snk-hud-label">MEILLEUR</div>
            <div class="snk-hud-value best" id="snkBest">0</div>
        </div>
    </div>

    <!-- Canvas + overlay -->
    <div class="snk-canvas-wrap">
        <canvas id="snkCanvas" width="560" height="560" tabindex="0"></canvas>

        <!-- Écran démarrage / game over -->
        <div class="snk-overlay visible" id="snkOverlay">
            <div class="snk-overlay-title neon-pink" id="snkOverlayTitle">SNAKE NÉON</div>
            <div class="snk-overlay-score" id="snkOverlayScore"></div>
            <div class="snk-overlay-sub" id="snkOverlaySub">Appuie sur une touche directionnelle pour commencer</div>
            <button class="snk-overlay-btn" id="snkStartBtn">▶ JOUER</button>
        </div>
    </div>

    <div class="snk-controls">
        ↑ ↓ ← → &nbsp;ou&nbsp; W A S D &nbsp;—&nbsp; ESPACE pour pause
    </div>
</div>

@section Scripts {
<script>
(function () {
    /* ── Config ─────────────────────────────────────── */
    const COLS      = 28;
    const ROWS      = 28;
    const CELL      = 20;           // px par cellule
    const BASE_MS   = 140;          // intervalle de base (ms)
    const MIN_MS    = 55;           // vitesse max
    const SPD_STEP  = 8;            // points pour gagner +1 niveau de vitesse

    /* ── État ───────────────────────────────────────── */
    let snake, dir, nextDir, food, score, best, interval, paused, running, bonus;

    best = parseInt(localStorage.getItem('snk_best') || '0');
    document.getElementById('snkBest').textContent = best;

    /* ── Canvas ─────────────────────────────────────── */
    const canvas = document.getElementById('snkCanvas');
    const ctx    = canvas.getContext('2d');

    /* ── Audio ──────────────────────────────────────── */
    let _ac = null;
    async function getAC() {
        if (!_ac) _ac = new (window.AudioContext || window.webkitAudioContext)();
        if (_ac.state !== 'running') await _ac.resume();
        return _ac;
    }

    async function playEat() {
        try {
            const ac  = await getAC();
            const now = ac.currentTime;
            const osc = ac.createOscillator();
            const g   = ac.createGain();
            osc.connect(g); g.connect(ac.destination);
            osc.type = 'sine';
            osc.frequency.setValueAtTime(520, now);
            osc.frequency.exponentialRampToValueAtTime(880, now + 0.08);
            g.gain.setValueAtTime(0.18, now);
            g.gain.exponentialRampToValueAtTime(0.001, now + 0.12);
            osc.start(now); osc.stop(now + 0.13);
        } catch (_) {}
    }

    async function playBonus() {
        try {
            const ac  = await getAC();
            const now = ac.currentTime;
            [0, 0.1, 0.2].forEach((dt, i) => {
                const osc = ac.createOscillator();
                const g   = ac.createGain();
                osc.connect(g); g.connect(ac.destination);
                osc.type = 'sine';
                osc.frequency.value = [660, 880, 1100][i];
                g.gain.setValueAtTime(0.2, now + dt);
                g.gain.exponentialRampToValueAtTime(0.001, now + dt + 0.1);
                osc.start(now + dt); osc.stop(now + dt + 0.11);
            });
        } catch (_) {}
    }

    async function playDie() {
        try {
            const ac  = await getAC();
            const now = ac.currentTime;
            const osc = ac.createOscillator();
            const g   = ac.createGain();
            osc.connect(g); g.connect(ac.destination);
            osc.type = 'sawtooth';
            osc.frequency.setValueAtTime(300, now);
            osc.frequency.exponentialRampToValueAtTime(60, now + 0.5);
            g.gain.setValueAtTime(0.35, now);
            g.gain.exponentialRampToValueAtTime(0.001, now + 0.55);
            osc.start(now); osc.stop(now + 0.56);
        } catch (_) {}
    }

    /* ── Init partie ─────────────────────────────────── */
    function startGame() {
        snake   = [{ x: 14, y: 14 }, { x: 13, y: 14 }, { x: 12, y: 14 }];
        dir     = { x: 1, y: 0 };
        nextDir = { x: 1, y: 0 };
        score   = 0;
        paused  = false;
        running = true;
        bonus   = null;

        spawnFood();
        updateHUD();
        hideOverlay();

        clearInterval(interval);
        interval = setInterval(tick, currentSpeed());
        draw();
    }

    function currentSpeed() {
        const level = Math.floor(score / SPD_STEP);
        return Math.max(MIN_MS, BASE_MS - level * 8);
    }

    /* ── Nourriture ─────────────────────────────────── */
    function spawnFood() {
        food = randFreeCell();
        /* Bonus doré toutes les 5 nourritures */
        if (score > 0 && score % 25 === 0) {
            bonus = randFreeCell();
            setTimeout(() => { bonus = null; draw(); }, 5000);
        }
    }

    function randFreeCell() {
        let cell;
        do {
            cell = { x: Math.floor(Math.random() * COLS), y: Math.floor(Math.random() * ROWS) };
        } while (snake.some(s => s.x === cell.x && s.y === cell.y));
        return cell;
    }

    /* ── Tick ────────────────────────────────────────── */
    function tick() {
        if (paused || !running) return;

        dir = { ...nextDir };
        const head = { x: snake[0].x + dir.x, y: snake[0].y + dir.y };

        /* Collision mur */
        if (head.x < 0 || head.x >= COLS || head.y < 0 || head.y >= ROWS) {
            return gameOver();
        }
        /* Collision soi-même */
        if (snake.some(s => s.x === head.x && s.y === head.y)) {
            return gameOver();
        }

        snake.unshift(head);

        /* Mange nourriture */
        if (head.x === food.x && head.y === food.y) {
            score += 10;
            playEat();
            spawnFood();
            resetInterval();
        } else if (bonus && head.x === bonus.x && head.y === bonus.y) {
            score += 50;
            bonus = null;
            playBonus();
            resetInterval();
        } else {
            snake.pop();
        }

        updateHUD();
        draw();
    }

    function resetInterval() {
        clearInterval(interval);
        interval = setInterval(tick, currentSpeed());
    }

    /* ── Game Over ───────────────────────────────────── */
    function gameOver() {
        running = false;
        clearInterval(interval);
        playDie();

        if (score > best) {
            best = score;
            localStorage.setItem('snk_best', best);
            document.getElementById('snkBest').textContent = best;
        }

        drawDeath();
        setTimeout(() => {
            document.getElementById('snkOverlayTitle').textContent  = 'GAME OVER';
            document.getElementById('snkOverlayTitle').style.color  = '#ff2d78';
            document.getElementById('snkOverlayScore').textContent  = `Score : ${score}  |  Meilleur : ${best}`;
            document.getElementById('snkOverlaySub').textContent    = '';
            document.getElementById('snkStartBtn').textContent      = '↺ REJOUER';
            showOverlay();
        }, 600);
    }

    /* ── HUD ─────────────────────────────────────────── */
    function updateHUD() {
        document.getElementById('snkScore').textContent = score;
        const lvl    = Math.floor(score / SPD_STEP);
        const maxLvl = Math.floor((BASE_MS - MIN_MS) / 8);
        const pct    = Math.min(100, 10 + (lvl / maxLvl) * 90);
        document.getElementById('snkSpeedFill').style.width = pct + '%';
        canvas.classList.toggle('max-speed', currentSpeed() <= MIN_MS);
    }

    /* ── Dessin ──────────────────────────────────────── */
    function draw() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        drawGrid();
        drawFood();
        if (bonus) drawBonus();
        drawSnake();
    }

    function drawGrid() {
        ctx.strokeStyle = 'rgba(0,212,255,0.04)';
        ctx.lineWidth   = 0.5;
        for (let x = 0; x <= COLS; x++) {
            ctx.beginPath(); ctx.moveTo(x * CELL, 0); ctx.lineTo(x * CELL, ROWS * CELL); ctx.stroke();
        }
        for (let y = 0; y <= ROWS; y++) {
            ctx.beginPath(); ctx.moveTo(0, y * CELL); ctx.lineTo(COLS * CELL, y * CELL); ctx.stroke();
        }
    }

    function drawSnake() {
        snake.forEach((seg, i) => {
            const x = seg.x * CELL;
            const y = seg.y * CELL;
            const isHead = i === 0;
            const r = CELL / 2 - 1;

            if (isHead) {
                /* Halo tête */
                ctx.shadowColor = '#ff2d78';
                ctx.shadowBlur  = 18;
                ctx.fillStyle   = '#ff2d78';
            } else {
                const ratio     = i / snake.length;
                ctx.shadowColor = '#00d4ff';
                ctx.shadowBlur  = 10 - ratio * 8;
                ctx.fillStyle   = `hsl(${190 - ratio * 30}, 100%, ${60 - ratio * 20}%)`;
            }

            ctx.beginPath();
            ctx.roundRect(x + 1, y + 1, CELL - 2, CELL - 2, isHead ? 6 : 4);
            ctx.fill();

            /* Yeux sur la tête */
            if (isHead) {
                ctx.shadowBlur  = 0;
                ctx.fillStyle   = '#fff';
                const ex = dir.x === 0 ? [4, CELL - 6] : dir.x > 0 ? [CELL - 7, CELL - 7] : [4, 4];
                const ey = dir.y === 0 ? [4, 4]        : dir.y > 0 ? [CELL - 7, 4]         : [4, CELL - 7];
                ctx.beginPath(); ctx.arc(x + ex[0], y + ey[0], 2.5, 0, 2 * Math.PI); ctx.fill();
                ctx.beginPath(); ctx.arc(x + ex[1], y + ey[1], 2.5, 0, 2 * Math.PI); ctx.fill();
            }
        });
        ctx.shadowBlur = 0;
    }

    function drawFood() {
        const x = food.x * CELL + CELL / 2;
        const y = food.y * CELL + CELL / 2;
        ctx.shadowColor = '#ff2d78';
        ctx.shadowBlur  = 16;
        ctx.font        = `${CELL - 2}px serif`;
        ctx.textAlign   = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText('🍎', x, y);
        ctx.shadowBlur  = 0;
    }

    function drawBonus() {
        const x = bonus.x * CELL + CELL / 2;
        const y = bonus.y * CELL + CELL / 2;
        ctx.shadowColor = '#FFD700';
        ctx.shadowBlur  = 20;
        ctx.font        = `${CELL - 2}px serif`;
        ctx.textAlign   = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText('⭐', x, y);
        ctx.shadowBlur  = 0;
    }

    function drawDeath() {
        ctx.fillStyle = 'rgba(255,45,120,0.12)';
        ctx.fillRect(0, 0, canvas.width, canvas.height);
    }

    /* ── Overlay ─────────────────────────────────────── */
    function showOverlay() { document.getElementById('snkOverlay').classList.add('visible'); }
    function hideOverlay() { document.getElementById('snkOverlay').classList.remove('visible'); }

    /* ── Contrôles ───────────────────────────────────── */
    const DIRS = {
        ArrowUp:    { x: 0, y: -1 }, w: { x: 0, y: -1 }, W: { x: 0, y: -1 },
        ArrowDown:  { x: 0, y:  1 }, s: { x: 0, y:  1 }, S: { x: 0, y:  1 },
        ArrowLeft:  { x: -1, y: 0 }, a: { x: -1, y: 0 }, A: { x: -1, y: 0 },
        ArrowRight: { x:  1, y: 0 }, d: { x:  1, y: 0 }, D: { x:  1, y: 0 },
    };

    document.addEventListener('keydown', e => {
        if (e.key === ' ') {
            e.preventDefault();
            if (!running) return;
            paused = !paused;
            return;
        }

        const d = DIRS[e.key];
        if (!d) return;
        e.preventDefault();

        if (!running) { startGame(); return; }

        /* Interdit demi-tour */
        if (d.x === -dir.x && d.y === -dir.y) return;
        nextDir = d;
    });

    document.getElementById('snkStartBtn').addEventListener('click', startGame);

    /* ── Premier rendu ───────────────────────────────── */
    draw();
})();
</script>
}
